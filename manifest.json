{
  "manifest_version": 3,
  "name": "Lat2Cyr",
  "version": "1.0",
  "description": "Convert Serbian Latin to Cyrillic via popup or context menu.",
  "permissions": [
    "menus",
    "scripting",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "theme_icons": [
      {
        "light": "icons/icon-light.svg",
        "dark": "icons/icon-dark.svg",
        "size": 16
      },
      {
        "light": "icons/icon-light.svg",
        "dark": "icons/icon-dark.svg",
        "size": 32
      }
    ]
  },
  "background": {
    "scripts": [
      "script/utils.js",
      "script/background.js"
    ]
  },
  "icons": {
    "128": "icons/icon-light.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lat2cyr@jicbo.dev",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}